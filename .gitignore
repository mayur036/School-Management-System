# ───────────────────────────────
# Root .gitignore (monorepo level)
# ───────────────────────────────

# Dependencies
node_modules/
.pnp
.pnp.js
.yarn/

# Environment files (never commit secrets)
.env
.env.local
.env.development
.env.production
.env.test
.env.*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
bun-debug.log*

# Build output
dist/
build/
out/

# Caches
.cache/
.temp/
.tmp/
*.tsbuildinfo

# Test / coverage
coverage/
test/
.nyc_output/

# OS files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Editor / IDE
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ───────────────────────────────
# AI assistance (local only — not shared in the repo)
# ───────────────────────────────
.claude/
.agents/
design-system/

# Database dumps / local backups
*.sqlite
*.sqlite3
*.db
*.dump
*.bak

# JSON SECRETS
google.json