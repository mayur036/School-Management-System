# ───────────────────────────────
# Backend (Node / Express) .gitignore
# ───────────────────────────────

# Dependencies
node_modules/

# Environment files (DB creds, JWT secret — keep .env.example only)
.env
.env.local
.env.development
.env.production
.env.test
.env.*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
bun-debug.log*

# Build output
dist/
build/

# User uploads (runtime-generated)
uploads/
public/uploads/

# Test / coverage
coverage/
.nyc_output/

# Local DB artifacts / dumps
*.sqlite
*.sqlite3
*.db
*.dump
*.bak

# Caches
.cache/
*.tsbuildinfo

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
